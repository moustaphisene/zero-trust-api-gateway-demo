{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Sécurité des API — Vue d'ensemble",
  "uid": "api-security-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Authentifications (succès vs échecs) — req/s",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(security_authentication_success_total[1m]))", "legendFormat": "succès", "refId": "A" },
        { "expr": "sum(rate(security_authentication_failure_total[1m]))", "legendFormat": "échecs", "refId": "B" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Accès refusés (RBAC/ABAC) — req/s",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(security_access_denied_total[1m]))", "legendFormat": "refus", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Dépassements de rate limit (total)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(security_ratelimit_exceeded_total)", "legendFormat": "rate-limit", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Accès aux données métier (total)",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(security_data_access_total)", "legendFormat": "data-access", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Services UP",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(up)", "legendFormat": "up", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latence HTTP Gateway (p95)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"api-gateway\"}[5m])) by (le))", "legendFormat": "p95", "refId": "A" }
      ]
    }
  ]
}